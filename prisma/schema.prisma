
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Category {
  id          String    @id @default(cuid())
  name        String
  description String?
  sortOrder   Int       @default(0)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id               String                    @id @default(cuid())
  code             String?                   @unique
  name             String
  categoryId       String
  category         Category                  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  brand            String?
  specification    String?
  model            String?
  unit             String                    @default("个")
  purchaseUnit     String?
  unitRatio        Float                     @default(1)
  lastPurchasePrice Float?
  referencePrice   Float?
  isPriceVolatile  Boolean                   @default(false)
  stock            Float                     @default(0)
  minStock         Float                     @default(0)
  imagePath        String?
  imageUrl         String?
  purchases          Purchase[]
  orderItems         OrderItem[]
  productSpecs       ProductSpec[]
  returnItems        SaleReturnItem[]
  purchaseReturns    PurchaseReturnItem[]
  businessCommissions BusinessCommission[]
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@index([name, brand, specification])
}

model Brand {
  id         String   @id @default(cuid())
  name       String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  specs      ProductSpec[]
}

model ProductSpec {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  brandId    String
  brand      Brand   @relation(fields: [brandId], references: [id], onDelete: Cascade)

  name       String
  unit       String  @default("个")

  salePrice  Float

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([productId, brandId, name])
}

model EntityPrice {
  id            String   @id @default(cuid())
  entityId      String
  entity        Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  productId     String
  lastPrice     Float
  transactionCount Int   @default(1)
  updatedAt     DateTime @updatedAt

  @@unique([entityId, productId])
}

model PurchaseOrder {
  id           String     @id @default(cuid())
  batchNo      String?    @unique
  supplierId   String?
  supplier     Supplier?  @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  supplierName String?
  purchaseDate DateTime   @default(now())
  remark       String?
  status       String     @default("draft")
  sentDate     DateTime?
  deliveredDate DateTime?
  completedDate DateTime?

  needDelivery Boolean         @default(false)
  deliveryStatus String        @default("not_delivered")
  driverName   String?
  driverPhone  String?
  estimatedDeliveryDate DateTime?

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  items        Purchase[]

  @@index([supplierId])
}

model Purchase {
  id           String          @id @default(cuid())
  orderId      String?
  order        PurchaseOrder?  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity     Int
  unitPrice    Float
  totalAmount  Float
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  supplierName String?
  purchaseDate DateTime        @default(now())
  remark       String?
  status       String          @default("draft")
  sentDate     DateTime?
  deliveredDate DateTime?
  completedDate DateTime?

  needDelivery Boolean         @default(false)
  deliveryStatus String        @default("not_delivered")
  driverName   String?
  driverPhone  String?
  estimatedDeliveryDate DateTime?

  photos       PurchasePhoto[]
  createdAt    DateTime        @default(now())

  returns      PurchaseReturn[]

  @@index([orderId])
}

model PurchaseReturn {
  id            String   @id @default(cuid())
  purchaseId    String
  purchase      Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  returnDate    DateTime @default(now())
  totalAmount   Float
  remark        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items         PurchaseReturnItem[]
}

model PurchaseReturnItem {
  id               String   @id @default(cuid())
  purchaseReturnId String
  purchaseReturn   PurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)
  productId        String
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  returnQuantity   Float
  unitPrice        Float
  amount           Float
  marketPrice      Float?
  createdAt        DateTime @default(now())
}

model CustomerCategory {
  id          String     @id @default(cuid())
  name        String
  description String?
  discount    Float      @default(0)
  contacts    Contact[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model SystemSetting {
  id                 String   @id @default("default")
  shopName           String   @default("折柳建材店")
  ownerName          String?
  phone              String?
  address            String?
  idleTimeoutMinutes Int      @default(5)
  lockPassword       String   @default("123456")
  updatedAt          DateTime @updatedAt
}

model BusinessCommission {
  id            String    @id @default(cuid())
  
  // 类型：OUTGOING (介绍人返点，支出) / INCOMING (供应商返点，收入)
  type          String    @default("OUTGOING")
  
  // 分类：INTRODUCER (介绍人) / SUPPLIER (供应商)
  category      String    @default("INTRODUCER")
  
  // 关联
  saleOrderId   String?
  saleOrder     SaleOrder? @relation(fields: [saleOrderId], references: [id], onDelete: Cascade)
  contactId     String?
  contact       Contact?   @relation("CommissionContact", fields: [contactId], references: [id], onDelete: SetNull)
  supplierId    String?
  supplier      Supplier?  @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  productId     String?
  product       Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
  
  // 金额
  amount        Float
  
  // 其他
  recordedAt    DateTime  @default(now())
  remark        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model DeliveryFee {
  id        String   @id @default(cuid())
  zoneName  String   @unique
  baseFee   Float    @default(0)
  perKgFee  Float    @default(0)
  perKmFee  Float    @default(0)
  minWeight Float    @default(0)
  maxWeight Float    @default(100)
  remark    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeliveryRecord {
  id              String    @id @default(cuid())
  saleOrderId     String?
  saleOrder       SaleOrder? @relation(fields: [saleOrderId], references: [id], onDelete: SetNull)
  zoneName        String
  recipientName   String
  recipientPhone  String?
  deliveryAddress String
  distance        Float     @default(0)
  weight          Float     @default(0)
  baseFee         Float     @default(0)
  distanceFee     Float     @default(0)
  weightFee       Float     @default(0)
  totalFee        Float     @default(0)
  deliveryStatus  String    @default("pending")
  deliveryDate    DateTime?
  driverName      String?
  driverPhone     String?
  remark          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model PaymentPlan {
  id           String    @id @default(cuid())
  customerId   String
  customer     Contact   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  projectId    String?
  planAmount   Float
  actualAmount Float     @default(0)
  dueDate      DateTime
  paidDate     DateTime?
  status       String    @default("pending")
  remark       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  actionType String
  entityType String
  entityId   String
  oldValue   String?
  newValue   String?
  operatorId String?
  ipAddress  String?
  timestamp  DateTime @default(now())
}

model SaleOrderPhoto {
  id          String   @id @default(cuid())
  saleOrderId String
  saleOrder   SaleOrder @relation(fields: [saleOrderId], references: [id], onDelete: Cascade)
  photoPath   String
  photoType   String   @default("handwritten")
  photoRemark String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PurchasePhoto {
  id          String   @id @default(cuid())
  purchaseId  String
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  photoPath   String
  photoType   String   @default("delivery")
  photoRemark String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CreditRecord {
  id            String    @id @default(cuid())
  customerId    String
  customer      Contact   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  recordType    String
  creditLimit   Float
  creditUsed    Float
  creditLevel   String
  riskLevel     String
  reason        String?
  operator      String?
  createdAt     DateTime  @default(now())
}

model CollectionRecord {
  id               String              @id @default(cuid())
  customerId       String
  customer         Contact             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  receivableId     String?
  receivable       Receivable?        @relation(fields: [receivableId], references: [id], onDelete: SetNull)
  collectionDate   DateTime            @default(now())
  collectionTime   String?             @default("00:00")
  collectionMethod String
  collectionResult String
  collectionAmount Float?
  followUpDate     DateTime?
  followUpTime     String?
  communication    String?
  nextPlan         String?
  remark           String?
  createdAt        DateTime           @default(now())
}

model InventoryCheck {
  id          String               @id @default(cuid())
  checkDate   DateTime             @default(now())
  operator    String?
  totalItems  Int                  @default(0)
  totalProfit Int                  @default(0)
  totalLoss   Int                  @default(0)
  status      String               @default("draft")
  remark      String?
  items       InventoryCheckItem[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model InventoryCheckItem {
  id          String         @id @default(cuid())
  checkId     String
  check       InventoryCheck @relation(fields: [checkId], references: [id], onDelete: Cascade)
  productId   String
  systemStock Int
  actualStock Int
  profitLoss  Int
  costPrice   Float
  amount      Float
  createdAt   DateTime       @default(now())
}

model Contact {
  id                   String   @id @default(cuid())
  code                 String   @unique
  name                 String
  primaryPhone         String?
  address              String?
  remark               String?
  contactType          String   @default("customer")
  valueScore           Float?
  autoTag              String?
  manualTag            String?
  creditLimit          Float    @default(0)
  creditUsed           Float    @default(0)
  creditLevel          String   @default("normal")
  lastCreditReviewDate DateTime?
  riskLevel            String   @default("low")
  blacklist            Boolean  @default(false)
  blacklistReason      String?
  customerCategoryId   String?
  customerCategory     CustomerCategory? @relation(fields: [customerCategoryId], references: [id], onDelete: SetNull)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  phonesObj            ContactPhone[]
  entityRoles          ContactEntityRole[]
  projectRoles         ContactProjectRole[]
  ordersAsBuyer        SaleOrder[]  @relation("BuyerContact")
  ordersAsIntroducer   SaleOrder[]  @relation("IntroducerContact")
  ordersAsPicker       SaleOrder[]  @relation("PickerContact")
  personalEntity       Entity?
  rebatesAsPlumber     Rebate[]
  supplierContacts     Supplier[]
  badDebtWriteOffs     BadDebtWriteOff[]
  paymentPlans         PaymentPlan[]
  collectionRecords    CollectionRecord[]
  creditRecords        CreditRecord[]
  slipAsCustomer       SaleSlip[]
  slipAsBuyer          SaleSlip[]  @relation("SaleSlipBuyer")
  slipAsIntroducer     SaleSlip[]  @relation("SaleSlipIntroducer")
  slipAsPicker         SaleSlip[]  @relation("SaleSlipPicker")
  businessCommissions  BusinessCommission[] @relation("CommissionContact")
}

model ContactPhone {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  phone     String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([contactId, phone])
  @@index([contactId])
}

model Supplier {
  id               String   @id @default(cuid())
  code             String   @unique
  name             String
  contactId        String?
  supplierContact  Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  phone            String?
  address          String?
  remark           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  purchases          Purchase[]
  purchaseOrders     PurchaseOrder[]
  businessCommissions BusinessCommission[]
}

model Entity {
  id          String   @id @default(cuid())
  name        String
  entityType  String
  contactId   String?  @unique
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  defaultPayer String?
  creditLimit Float    @default(0)
  creditUsed  Float    @default(0)
  creditScore      Float?
  creditLevel      String?
  riskLevel        String?
  lastCreditEvalDate DateTime?
  address     String?
  remark      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles   ContactEntityRole[]
  projects BizProject[]
  orders  SaleOrder[]
  legacyBills LegacyBill[]
  entityPrices EntityPrice[]
}

model BizProject {
  id            String   @id @default(cuid())
  name          String
  entityId      String
  entity        Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  address       String?
  status        String   @default("进行中")
  startDate     DateTime?
  endDate       DateTime?
  estimatedAmount Float?
  remark        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  roles   ContactProjectRole[]
  orders  SaleOrder[]
  legacyBills LegacyBill[]
}

model ContactEntityRole {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  entityId  String
  entity    Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  role      String
  isDefault Boolean  @default(false)
  remark    String?
  createdAt DateTime @default(now())

  @@unique([contactId, entityId, role])
  @@index([contactId])
  @@index([entityId])
}

model ContactProjectRole {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  projectId String
  project   BizProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role      String
  remark    String?
  createdAt DateTime @default(now())

  @@unique([contactId, projectId, role])
  @@index([contactId])
  @@index([projectId])
}

model SaleOrder {
  id               String   @id @default(cuid())
  invoiceNo        String?
  writtenInvoiceNo String?
  saleDate         DateTime @default(now())

  buyerId          String
  buyer            Contact  @relation("BuyerContact", fields: [buyerId], references: [id])

  introducerId     String?
  introducer       Contact? @relation("IntroducerContact", fields: [introducerId], references: [id])

  pickerId         String?
  picker           Contact? @relation("PickerContact", fields: [pickerId], references: [id])

  needDelivery     Boolean  @default(false)
  deliveryAddress  String?
  deliveryFee      Float    @default(0)

  projectId        String?
  project          BizProject? @relation(fields: [projectId], references: [id])

  paymentEntityId  String
  paymentEntity    Entity   @relation(fields: [paymentEntityId], references: [id])

  totalAmount      Float
  discount         Float    @default(0)
  paidAmount       Float    @default(0)
  writeOffAmount   Float    @default(0)

  status           String   @default("completed")
  remark           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items            OrderItem[]
  payments         OrderPayment[]
  rebates          Rebate[]
  receivables      Receivable[]
  photos           SaleOrderPhoto[]
  returns          SaleReturn[]
  badDebtWriteOffs BadDebtWriteOff[]
  deliveryRecords  DeliveryRecord[]
}

model SaleReturn {
  id           String   @id @default(cuid())
  saleOrderId  String
  saleOrder    SaleOrder @relation(fields: [saleOrderId], references: [id], onDelete: Cascade)
  returnDate   DateTime @default(now())
  totalAmount  Float
  remark       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items        SaleReturnItem[]
}

model SaleReturnItem {
  id            String   @id @default(cuid())
  saleReturnId  String
  saleReturn    SaleReturn @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)

  productId     String
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  returnQuantity Float
  unitPrice     Float
  amount        Float

  createdAt    DateTime @default(now())
}

model SaleSlip {
  id                     String   @id @default(cuid())
  customerId             String?
  customer               Contact? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  projectId              String?
  buyerId               String?
  buyer                 Contact? @relation("SaleSlipBuyer", fields: [buyerId], references: [id], onDelete: SetNull)
  introducerId          String?
  introducer            Contact? @relation("SaleSlipIntroducer", fields: [introducerId], references: [id], onDelete: SetNull)
  pickerId              String?
  picker                Contact? @relation("SaleSlipPicker", fields: [pickerId], references: [id], onDelete: SetNull)
  pickerName            String?
  pickerPhone           String?
  pickerType            String?
  writtenInvoiceNo      String?
  paymentEntityId       String?
  needDelivery          Boolean  @default(false)
  deliveryAddress       String?
  deliveryFee           Float    @default(0)
  totalAmount          Float    @default(0)
  discount             Float    @default(0)
  discountRate          Float    @default(100)
  paidAmount           Float    @default(0)
  saleDate             DateTime @default(now())
  remark               String?
  status               String   @default("draft")
  items                SaleSlipItem[]
  payments             String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model SaleSlipItem {
  id        String   @id @default(cuid())
  slipId    String
  slip      SaleSlip @relation(fields: [slipId], references: [id], onDelete: Cascade)
  productId String
  quantity  Int
  unitPrice Float
  subtotal  Float
  createdAt DateTime @default(now())
}

model BadDebtWriteOff {
  id              String   @id @default(cuid())
  contactId       String
  contact         Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  saleOrderId     String?
  saleOrder       SaleOrder? @relation(fields: [saleOrderId], references: [id], onDelete: SetNull)
  originalAmount  Float
  writtenOffAmount Float
  finalAmount     Float
  writeOffType    String   @default("bad_debt")
  reason          String?
  operatorNote    String?
  approvedBy      String?
  approvedAt      DateTime?
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  createdBy       String?
  updatedAt       DateTime @updatedAt
}

model OrderItem {
  id                   String   @id @default(cuid())
  orderId              String
  order                SaleOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId            String
  product              Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity             Int
  unitPrice            Float
  costPriceSnapshot    Float
  sellingPriceSnapshot Float
  subtotal             Float
  createdAt            DateTime @default(now())
}

model OrderPayment {
  id         String   @id @default(cuid())
  orderId    String
  order      SaleOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount     Float
  method     String
  payerName  String?
  paidAt     DateTime @default(now())
  remark     String?
  createdAt  DateTime @default(now())
}

model Receivable {
  id                String               @id @default(cuid())
  orderId           String
  order             SaleOrder            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  originalAmount    Float
  paidAmount        Float                @default(0)
  remainingAmount   Float
  agreedPaymentDate DateTime?
  isOverdue         Boolean              @default(false)
  overdueDays       Int                  @default(0)
  status            String               @default("pending")
  settlementDate     DateTime?
  remark            String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  collectionRecords CollectionRecord[]
  auditLogs         ReceivableAuditLog[]
}

model ReceivableAuditLog {
  id                String  @id @default(cuid())
  receivableId      String
  receivable        Receivable @relation(fields: [receivableId], references: [id], onDelete: Cascade)
  actionType        String
  changeType        String
  oldValue          String?
  newValue          String?
  oldAmount         Float?
  newAmount         Float?
  oldStatus         String?
  newStatus         String?
  operator          String?
  reason            String?
  remark            String?
  createdAt         DateTime @default(now())

  @@index([receivableId])
  @@index([createdAt])
  @@index([actionType])
}

model LegacyBill {
  id                String   @id @default(cuid())
  entityId          String
  entity            Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  projectId         String?
  project           BizProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  billDate          DateTime @default(now())
  originalAmount    Float
  paidAmount        Float    @default(0)
  remainingAmount   Float
  status            String   @default("pending")
  remark            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([entityId])
  @@index([status])
}

